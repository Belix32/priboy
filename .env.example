# Прибой — Environment Variables
# Copy this file to .env and fill in your values

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_ADMIN_EMAIL=admin@priboi.ru

# Optional: for npm run db:fix (apply RLS migration)
# SUPABASE_ACCESS_TOKEN=your-personal-access-token

# Server-side only (Vercel — NOT VITE_*):
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# YOOKASSA_SHOP_ID=your-shop-id
# YOOKASSA_SECRET_KEY=your-secret-key
# RESEND_API_KEY=re_xxx
# NOTIFICATION_FROM_EMAIL=Прибой <noreply@yourdomain.ru>
# SITE_URL=https://priboy-six.vercel.app
